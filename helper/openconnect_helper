#!/usr/bin/env python3
"""Privileged helper daemon for openconnect. Runs as root via launchd.

Listens on a Unix socket, receives openconnect args + cookie as JSON,
spawns openconnect as root, and streams its output back to the caller.
"""
import json
import os
import shutil
import socket
import subprocess
import threading

SOCKET_PATH = "/var/run/openconnect-helper.sock"


def find_openconnect():
    for candidate in ["/opt/homebrew/bin/openconnect", "/usr/local/bin/openconnect"]:
        if os.path.isfile(candidate):
            return candidate
    found = shutil.which("openconnect")
    if found:
        return found
    raise FileNotFoundError("openconnect binary not found")


def handle_connection(conn, openconnect_path):
    try:
        data = b""
        while b"\n" not in data:
            chunk = conn.recv(4096)
            if not chunk:
                return
            data += chunk

        msg = json.loads(data.split(b"\n")[0])
        cookie = msg["cookie"]
        args = msg["args"]

        proc = subprocess.Popen(
            [openconnect_path] + args,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
        proc.stdin.write(cookie.encode() + b"\n")
        proc.stdin.close()

        for line in proc.stdout:
            try:
                conn.sendall(line)
            except (BrokenPipeError, OSError):
                proc.terminate()
                proc.wait()
                return
        proc.wait()
    except Exception as e:
        try:
            conn.sendall("Helper error: {}\n".format(e).encode())
        except Exception:
            pass
    finally:
        conn.close()


def main():
    openconnect_path = find_openconnect()
    print("Using openconnect: {}".format(openconnect_path), flush=True)

    if os.path.exists(SOCKET_PATH):
        os.unlink(SOCKET_PATH)

    server_sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server_sock.bind(SOCKET_PATH)
    os.chmod(SOCKET_PATH, 0o666)
    server_sock.listen(5)
    print("Listening on {}".format(SOCKET_PATH), flush=True)

    while True:
        conn, _ = server_sock.accept()
        threading.Thread(
            target=handle_connection,
            args=(conn, openconnect_path),
            daemon=True,
        ).start()


if __name__ == "__main__":
    main()
